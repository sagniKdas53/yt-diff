# YT-DB options

DB_USERNAME=ytdiff
DB_NAME=vidlist
DB_HOST=yt-db

# PGADMIN options
# See pg_admin_email.txt and pg_admin_password.txt for credentials

# YT-DIFF options
PROTOCOL=https
PORT=8888
BASE_URL=/ytdiff
HIDE_PORTS=true
NATIVE_HTTPS_SUPPORT=false
NO_COLOR=true

# Cookies file for yt-dlp, if you don't need it, leave it blank
# Using a relative path is okay, but an absolute path works best
CONTAINER_COOKIES_FILE=/home/ytdiff/cookies.txt
# Rate limiting settings (Set to 0 to disable throttling)
RATE_LIMIT_GLOBAL_MAX_REQUESTS=10
RATE_LIMIT_ACTION_MAX_REQUESTS=0
CACHE_MAX_ITEMS=500
# The front-end will refresh the file 5 mins before expiry (300000 ms), so don't set it less than that, also this is in seconds not ms
CACHE_MAX_AGE=3600
ACTION_WINDOW_SEC=3600

# Registration
ALLOW_REGISTRATION=true
# Max users allowed to sign up, default is 15
MAX_USERS=1

# Using a relative path is okay, but a absolute path works best
CONTAINER_SAVE_PATH=/home/ytdiff/Videos/yt-dlp/
# 0 works but don't use it, please
SLEEP=3
# https://github.com/TeamNewPipe/NewPipe/issues/875#issuecomment-347592489
CHUNK_SIZE_DEFAULT=10
# For some reason, subtitles are not being saved properly with certain formats, so disabling it by default
SAVE_SUBTITLES=false
# Not saving these as well as these are not that important to me right now
SAVE_COMMENTS=false
# Saving description
SAVE_DESCRIPTION=true
# These are necessary for proper thumbnail display in the webui
SAVE_THUMBNAIL=true
# Having issues with certain filenames, so restricting them
RESTRICT_FILENAMES=true
# 255 is the max filename length for ext4 filesystems, but leaving some buffer
MAX_FILENAME_LENGTH=240

MAX_DOWNLOADS=1
MAX_LISTINGS=1
CLEANUP_INTERVAL=*/30 * * * *
PROCESS_MAX_AGE=1800000

# CRON expression used here, use https://crontab.guru/ for examples
UPDATE_SCHEDULED=0 4 * * *
PRUNE_INTERVAL=0 2 * * *
TZ_PREFERRED=Asia/Kolkata

#GLUETUN CONF
#PROVIDER
SERVICE_PROVIDER_VPN=nordvpn
#FREE=on
HTTP_PROXY=on
HTTP_PROXY_LISTENING_ADDRESS=:3128
# This password being open doesn't matter as the port is exposed only inside the docker subnet
HTTP_PROXY_USER=proton
HTTP_PROXY_PASSWORD=n436b5CXcPkrRbKADE1VUhq
HTTP_PROXY_STEALTH=on
#PROXY_STRING=http://proton:n436b5CXcPkrRbKADE1VUhq@gluetun:3128/

# OPENVPN
#JAPAN
SERVER_COUNTRIES_PREFERRED=Japan

# Env specific to my setup, you can ignore these if you want, 
# but make sure to update the paths in the docker-compose.yml file accordingly
DB_LOCATION=/home/pi4/Documents/yt-db-data/
HOSTNAME=pi4.tail9ece4.ts.net
LOG_LEVELS=trace
HOST_SAVE_PATH=/home/pi4/Videos/yt-dlp/
DB_BACKUP_LOCATION=/home/pi4/Documents/yt-db-backups/
HOST_COOKIES_FILE=/home/pi4/Projects/docker-composes/yt-diff/cookies_secret.txt